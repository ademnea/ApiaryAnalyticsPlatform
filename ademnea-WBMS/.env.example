APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ademnea
DB_USERNAME=postgres
DB_PASSWORD=          # your local PostgreSQL password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ademnea.ac.ug"
MAIL_FROM_NAME="AdEMNEA Beehive Monitor"

# -----------------------------------------------------------------------
# MAIL SETUP — choose ONE option and fill in the values below.
#
# Option A: Log driver (default — no emails sent, output goes to storage/logs/laravel.log)
#   MAIL_MAILER=log
#
# Option B: Mailtrap (recommended for local development — https://mailtrap.io)
#   MAIL_MAILER=smtp
#   MAIL_HOST=sandbox.smtp.mailtrap.io
#   MAIL_PORT=2525
#   MAIL_USERNAME=          # from Mailtrap dashboard
#   MAIL_PASSWORD=          # from Mailtrap dashboard
#   MAIL_ENCRYPTION=tls
#
# Option C: Gmail SMTP (sends real emails)
#   MAIL_MAILER=smtp
#   MAIL_HOST=smtp.gmail.com
#   MAIL_PORT=587
#   MAIL_USERNAME=          # your Gmail address
#   MAIL_PASSWORD=          # Gmail App Password (NOT your login password)
#                           # Generate at: Google Account > Security > App passwords
#   MAIL_ENCRYPTION=tls
#
# Option D: Production — set via server environment variables, never commit here.
# -----------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
